// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OnboardingUserRole {
  personal
  professional
}

enum OnboardingMeasurementSystem {
  imperial
  metric
}

enum OnboardingSexAtBirth {
  male
  female
  other
}

enum OnboardingPreferredFeature {
  ai_doctor
  lab_interpretation
  top_doctors
}

/// Authentication identity used by registration, login, Google OAuth, and password reset.
/// Email is normalized to lowercase in application code. Unique index on `email`.
/// - Email/password: `passwordHash` set, `googleId` null.
/// - Google-only: `googleId` set, `passwordHash` null until the user sets a password.
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String?
  googleId     String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  resetTokens PasswordResetToken[]
  profile     UserProfile?
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([tokenHash])
}

/// Health / onboarding data separated from auth credentials (1:1 with User).
model UserProfile {
  userId String @id
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  role           OnboardingUserRole
  preferredName  String
  confirmedAdult Boolean
  region         String

  ageYears            Int
  measurementSystem OnboardingMeasurementSystem
  /// Numeric string as entered in the wizard (e.g. "155" lb or "70" kg).
  weight              String
  heightFeet          String?
  heightInches        String?
  heightCm            String?

  sexAtBirth       OnboardingSexAtBirth
  preferredFeature OnboardingPreferredFeature

  onboardingCompletedAt DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
