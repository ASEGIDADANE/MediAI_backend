// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserAppRole {
  user
  admin
}

enum OnboardingUserRole {
  personal
  professional
}

enum OnboardingMeasurementSystem {
  imperial
  metric
}

enum OnboardingSexAtBirth {
  male
  female
  other
}

enum OnboardingPreferredFeature {
  ai_doctor
  lab_interpretation
  top_doctors
}

/// Verification state for professional (doctor) accounts.
///   - `pending`  – default after professional onboarding; doctor cannot
///                  access the dashboard yet. While `verificationSubmittedAt`
///                  is null they are still drafting; once non-null they're
///                  awaiting admin review.
///   - `verified` – admin approved; doctor has full access and appears on the
///                  public Top Doctors list.
///   - `rejected` – admin rejected; doctor sees the reason and may edit +
///                  re-submit (which clears `verificationReviewedAt`).
enum ProfessionalVerificationStatus {
  pending
  verified
  rejected
}

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  passwordHash String?
  googleId     String?     @unique
  appRole      UserAppRole @default(user)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  resetTokens       PasswordResetToken[]
  profile           UserProfile?
  supportReports    SupportReport[]
  accountAuditLogs  AccountAuditLog[]

  /// `ChatConversation`s the user *owns* (asks the AI; for personal-mode chats this is
  /// the caller — for the professional clinical assistant it's the doctor).
  chatConversations         ChatConversation[] @relation("ChatOwner")
  /// `ChatConversation`s where the user is the *subject* (the patient a doctor is
  /// asking the clinical assistant about). Always null for the patient's own personal
  /// chats.
  patientChatConversations  ChatConversation[] @relation("ChatPatient")

  doctorThreads     DoctorPatientThread[]  @relation("DoctorThreads")
  patientThreads    DoctorPatientThread[]  @relation("PatientThreads")
  sentDoctorPatientMessages DoctorPatientMessage[] @relation("DoctorPatientMessageSender")
}

/// Append-only style log for compliance; metadata must not store full PHI body text (field names / sizes only).
enum AccountAuditAction {
  profile_patch
  medical_history_put
  ai_doctor_setup_patch
  data_export
  account_delete_initiated
}

model AccountAuditLog {
  id        String            @id @default(uuid())
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    AccountAuditAction
  /// Best-effort client IP; trust X-Forwarded-For only behind a trusted reverse proxy
  ip        String?           @db.VarChar(64)
  userAgent String?           @db.VarChar(512)
  /// Non-PHI: e.g. { "fields": ["age"], "byteLength": 1234 }
  metadata  Json?
  createdAt DateTime          @default(now())

  @@index([userId, createdAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([tokenHash])
}

/// Health / onboarding data separated from auth credentials (1:1 with User).
model UserProfile {
  userId String @id
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  role           OnboardingUserRole
  preferredName  String
  confirmedAdult Boolean
  region         String

  ageYears            Int
  measurementSystem OnboardingMeasurementSystem
  /// Numeric string as entered in the wizard (e.g. "155" lb or "70" kg).
  weight              String
  heightFeet          String?
  heightInches        String?
  heightCm            String?

  sexAtBirth       OnboardingSexAtBirth
  preferredFeature OnboardingPreferredFeature

  /// Opaque JSON matching MediAI `ProfessionalProfile` (see dashboard-content).
  professionalProfile Json?
  /// Opaque JSON matching MediAI `MedicalHistoryData`.
  medicalHistory        Json?
  /// Replaces `mediai-ai-doctor-setup-completed` in localStorage when synced.
  aiDoctorSetupCompleted Boolean                 @default(false)

  /// Doctor verification (only meaningful when `role = professional`).
  /// Null means "not applicable" (personal users).
  verificationStatus      ProfessionalVerificationStatus? @map("verification_status")
  /// When the doctor clicked "Submit for review" with a complete profile.
  /// Null while still drafting; non-null while pending review.
  verificationSubmittedAt DateTime? @map("verification_submitted_at")
  /// When the admin approved or rejected the submission.
  verificationReviewedAt  DateTime? @map("verification_reviewed_at")
  /// Admin's `User.id` who reviewed the submission.
  verificationReviewedBy  String?   @map("verification_reviewed_by")
  /// Admin's note – mainly used to explain rejections.
  verificationNotes       String?   @map("verification_notes") @db.VarChar(2000)

  onboardingCompletedAt DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([verificationStatus])
}

/// Optional persistence for POST /api/chat/report-issue.
model SupportReport {
  id        String   @id @default(uuid())
  message   String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
}

enum ChatThreadKind {
  personal
  general
}

enum ChatMessageRole {
  user
  assistant
  system
}

/// One chat thread. Personal: `userId` set; general: `userId` may be null (anonymous).
///
/// `patientUserId` is the *subject* of a clinical-assistant conversation — set only
/// when a professional caller is asking the assistant about one of their patients.
/// For ordinary patient-side personal chats it's null. The pair `(userId,
/// patientUserId, kind)` together identifies a doctor↔patient context, so the LLM
/// is fed the patient's profile (not the doctor's) for those rows.
model ChatConversation {
  id   String         @id @default(uuid())
  kind ChatThreadKind
  /// Null for anonymous general; otherwise the *caller* who owns the thread.
  userId            String?
  user              User?   @relation("ChatOwner", fields: [userId], references: [id], onDelete: Cascade)
  /// When the caller is a doctor and the conversation is *about* a patient,
  /// this is that patient's userId. Null in every other case.
  patientUserId     String?
  patient           User?   @relation("ChatPatient", fields: [patientUserId], references: [id], onDelete: Cascade)
  /// Correlates unauthenticated general turns (not PHI).
  clientSessionId   String?
  /// Last activity for simple ordering.
  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())

  messages ChatMessage[]

  @@index([userId, kind])
  @@index([userId, patientUserId, kind])
  @@index([clientSessionId, kind])
}

model ChatMessage {
  id             String   @id @default(uuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           ChatMessageRole
  content        String   @db.Text
  /// Optional: { citations, model, usage, ... } — not logged at `info` in full.
  metadata       Json?
  createdAt      DateTime @default(now())

  @@index([conversationId, createdAt])
}

/// RAG source document (global guidelines — not per-user).
enum DocumentAudience {
  all
  personal_guidance
  general_only
}

model Document {
  id        String           @id @default(uuid())
  title     String
  source    String
  audience  DocumentAudience
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  chunks DocumentChunk[]

  @@index([audience, isActive])
}

/// Chunk with pgvector column — embeddings inserted/queried via raw SQL (see `RagService`); Prisma `create` may omit `embedding` use `$executeRaw`.
model DocumentChunk {
  id         String   @id @default(uuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  content    String   @db.Text
  position   Int
  embedding  Unsupported("vector(1536)")

  @@index([documentId, position])
}

/// Public directory entry for MediAI "Top Doctors" (brochure-style; not linked to `User` in v1).
/// Fees are **USD whole dollars** (same as MediAI `TopDoctor.consultationFees`).
model TopDoctor {
  id        String @id @default(uuid())
  name      String
  role      String
  specialty String
  subSpecialty String @map("sub_specialty")

  yearsOfExperience Int @map("years_of_experience")
  /// USD whole dollars (v1; matches frontend `consultationFees.video`)
  videoFee  Int    @map("video_fee")
  /// USD whole dollars
  writtenFee Int   @map("written_fee")

  heroImageUrl String @map("hero_image_url")

  educationDegree String @map("education_degree")
  educationYear   String @map("education_year")

  publicationsSummary String @map("publications_summary")

  /// JSON: string[] (disease labels)
  diseases     Json
  /// JSON: string[] (biography paragraphs)
  biography    Json
  /// JSON: { title: string; subtitle: string }[]
  experience   Json
  /// JSON: { title: string; subtitle: string }[]
  affiliations Json

  published Boolean @default(true)
  sortOrder Int?    @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([published, specialty])
  @@index([published, sortOrder])
  @@map("top_doctor")
}

/// Marketing blog post (MediAI `BlogArticleDto` in `src/lib/blog-api.ts`).
/// `date` in API = `dateDisplay` if set, else formatted `publishedAt` (en-US).
model BlogArticle {
  id         String   @id @default(uuid())
  title      String
  category   String
  author     String
  readTime   String   @map("read_time")
  imageSrc   String   @map("image_src")
  intro      String   @db.Text
  /// JSON: { title: string; body: string }[]
  sections   Json
  published  Boolean  @default(true)
  publishedAt DateTime @map("published_at")
  /// Exact display string e.g. "Jan 07, 2025" (optional; recommended for CMS parity)
  dateDisplay String?  @map("date_display")
  sortOrder  Int?     @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([published, publishedAt(sort: Desc)])
  @@index([published, category])
  @@map("blog_article")
}

/// Singleton (id = `default`) — homepage curation matching MediAI `featuredBlogArticleId` + `*ArticleIds` lists.
model BlogHomeConfig {
  id     String @id @default("default")
  /// UUID of featured article
  featuredArticleId String? @map("featured_article_id")
  /// JSON string[] of UUIDs
  popularArticleIds            Json @map("popular_article_ids")
  aiHealthcareArticleIds      Json @map("ai_healthcare_article_ids")
  secondOpinionArticleIds       Json @map("second_opinion_article_ids")
  companyNewsArticleIds         Json @map("company_news_article_ids")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("blog_home_config")
}

/// Static help / education page (MediAI `ResourcePageTemplate` — symptom guide, glossary, knowledge base).
model EducationResource {
  id          String   @id @default(uuid())
  /// `symptom-guide` | `glossary` | `knowledge-base` (enforced in app; unique)
  slug        String   @unique
  title       String
  description String   @db.Text
  /// JSON: string[] (bullet cards)
  bullets     Json
  /// Same as `slug` for `iconKey` in API (optional in DB)
  iconKey     String?  @map("icon_key")
  published   Boolean  @default(true)
  sortOrder   Int?     @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([published, sortOrder])
  @@map("education_resource")
}

/// Public directory for dashboard “Healthcare Facility Locator” (MediAI consumes `GET /health-facilities` — see `health-facilities-api.ts`).
enum HealthcareFacilityType {
  hospital
  pharmacy
  clinic
}

model HealthcareFacility {
  id        String                 @id
  name      String
  type      HealthcareFacilityType
  address   String
  phone     String
  rating    Float
  verified  Boolean                @default(false)
  latitude  Float
  longitude Float
  openNow   Boolean                @default(false) @map("open_now")
  published Boolean                @default(true)
  createdAt DateTime               @default(now()) @map("created_at")
  updatedAt DateTime               @updatedAt @map("updated_at")

  @@index([published, type])
  @@map("healthcare_facility")
}

/// Direct messaging thread between one doctor (professional UserProfile) and one patient
/// (personal UserProfile). The `(doctorUserId, patientUserId)` pair is unique so we
/// always have at most one open thread per pairing — fetching is "find or create".
model DoctorPatientThread {
  id            String   @id @default(uuid())
  doctorUserId  String
  doctor        User     @relation("DoctorThreads", fields: [doctorUserId], references: [id], onDelete: Cascade)
  patientUserId String
  patient       User     @relation("PatientThreads", fields: [patientUserId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  messages      DoctorPatientMessage[]

  @@unique([doctorUserId, patientUserId])
  @@index([doctorUserId, updatedAt(sort: Desc)])
  @@index([patientUserId, updatedAt(sort: Desc)])
  @@map("doctor_patient_thread")
}

/// One message inside a `DoctorPatientThread`. `senderUserId` is either the doctor
/// or the patient (must be one of the two participants of the thread, enforced by
/// service layer).
model DoctorPatientMessage {
  id           String   @id @default(uuid())
  threadId     String
  thread       DoctorPatientThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderUserId String
  sender       User     @relation("DoctorPatientMessageSender", fields: [senderUserId], references: [id], onDelete: Cascade)
  body         String
  readAt       DateTime?
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([threadId, createdAt])
  @@map("doctor_patient_message")
}

/// Admin-managed pricing tier ("Free", "Lite", "Pro", …). Surfaces on the public
/// pricing page and on `/admin/subscriptions`. Prices are stored in minor units
/// (cents) to avoid floating-point drift; the API returns both the integer and
/// a pre-formatted display string ("$3.99").
///
/// `SubscriptionPlan` is intentionally standalone: until a payment provider is
/// integrated there is no per-user link. Subscriber counts on the admin page
/// are computed lazily server-side (currently always 0 for paid tiers and the
/// live user count for the lone "free" tier when present).
model SubscriptionPlan {
  id                String   @id @default(uuid())
  /// Display name (must be unique — used as the tier identifier in copy).
  name              String   @unique
  description       String?  @db.VarChar(500)
  monthlyPriceCents Int      @default(0) @map("monthly_price_cents")
  yearlyPriceCents  Int      @default(0) @map("yearly_price_cents")
  /// ISO-4217 3-letter currency code (defaults to USD).
  currency          String   @default("USD") @db.VarChar(3)
  /// JSON `string[]` of feature bullet points (free-form copy).
  features          Json     @default("[]")
  /// When false, the plan is hidden from the public pricing page. Admins still
  /// see it on `/admin/subscriptions` so they can re-enable or delete it.
  active            Boolean  @default(true)
  /// Public ordering on the pricing page (lower = leftmost). Admin list shows
  /// the same order.
  sortOrder         Int      @default(0) @map("sort_order")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([active, sortOrder])
  @@map("subscription_plan")
}
