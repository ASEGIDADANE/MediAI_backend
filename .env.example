# =============================================================================
# MediAI backend — environment template
# Copy to .env and adjust values:
#   PowerShell: Copy-Item .env.example .env
# =============================================================================

# --- Database (PostgreSQL) ---------------------------------------------------
# Required by Nest (PrismaService) at startup via ConfigService.
#
# Local Docker (see docker-compose.yml — user/password/db: medi_ai / medi_ai / medi_ai):
DATABASE_URL="postgresql://medi_ai:medi_ai@localhost:5432/medi_ai?schema=public"
#
# Custom install: replace USER, PASSWORD, host, port, database name.
# Prisma CLI also reads DATABASE_URL via prisma.config.ts (loads dotenv).

# --- HTTP API ----------------------------------------------------------------
# Port for Nest (default 4000 keeps 3000 free for Next.js or other frontends)
PORT=4000
NODE_ENV=development

# --- JWT (registration, login, protected routes) ---------------------------
# MUST be a long random string in production. Never commit a real .env file.
JWT_SECRET=change-me-to-a-long-random-secret
# Short-lived access token (default 15m). Clients must use refresh token to renew.
ACCESS_TOKEN_EXPIRES=15m
# Long-lived refresh token signing secret — must be DIFFERENT from JWT_SECRET.
REFRESH_TOKEN_SECRET=change-me-to-a-different-long-random-secret
# Refresh token lifetime (default 7 days).
REFRESH_TOKEN_EXPIRES=7d

# --- Frontend (CORS, password-reset links, OAuth redirect) -------------------
FRONTEND_URL=http://localhost:3000

# --- Google OAuth (optional) -------------------------------------------------
# Leave empty to disable Google routes until configured in Google Cloud Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match an Authorized redirect URI (backend route):
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# =============================================================================
# Database setup (after .env exists with DATABASE_URL)
# =============================================================================
# Start Postgres:  docker compose up -d
# Apply migrations: npm run prisma:migrate
#   (production / CI:     npx prisma migrate deploy)
# Regenerate client: npm run prisma:generate   (also runs on npm install)
# =============================================================================
