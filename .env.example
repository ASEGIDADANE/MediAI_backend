# Database (PostgreSQL)
# Local dev: from this folder run `docker compose up -d` (user medi_ai, password medi_ai).
# Default compose maps host port 5433 -> 5432 in the container (avoids conflict with a system Postgres on 5432).
# Then: `npx prisma migrate deploy` (or `prisma migrate dev`)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5433/medi_ai?schema=public"

# Server (use 4000 if Next.js uses 3000)
PORT=4000
NODE_ENV=development

# JWT (generate a long random string for production)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES=7d

# Frontend (CORS + password-reset links + Google OAuth redirect)
FRONTEND_URL=http://localhost:3000

# Dev admin created by `npx prisma db seed` (email/password sign-in, appRole=admin)
# SEED_DEV_ADMIN=false
# DEV_ADMIN_EMAIL=admin@mediai.dev
# DEV_ADMIN_PASSWORD=ChangeMeDev1!

# Google OAuth — optional; leave empty to disable Google routes until configured
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match Authorized redirect URI in Google Cloud Console
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# After schema changes: npx prisma migrate deploy

# --- Admin bootstrap (read by `npx prisma db seed`) ---
# Each (email, password) pair becomes a user with appRole=admin. Re-running
# the seed is idempotent: existing admins are left alone, existing non-admins
# are promoted, missing users are created. Passwords are bcrypt-hashed; each
# must be at least 8 characters.
#
# 1) Single admin (back-compat shortcut):
# SEED_ADMIN_EMAIL=admin@yourdomain.com
# SEED_ADMIN_PASSWORD=change-me-to-something-strong
#
# 2) Multiple admins (numbered, gaps allowed, scanned up to 50):
# SEED_ADMIN_1_EMAIL=alice@yourdomain.com
# SEED_ADMIN_1_PASSWORD=alice-strong-password
# SEED_ADMIN_2_EMAIL=bob@yourdomain.com
# SEED_ADMIN_2_PASSWORD=bob-strong-password
#
# Set this to `true` to also overwrite the bcrypt password of every admin
# whose row already exists (useful when you forgot a local password). Leave
# unset / `false` to never silently rewrite an existing password.
# SEED_ADMIN_RESET_PASSWORD=false

# --- Demo data (patient + doctor users, chats, doctor↔patient thread, subscription plans if empty) ---
# Runs on `npx prisma db seed` unless disabled:
# SEED_DEMO_DATA=false
# Shared password for patient.demo@mediai.dev and doctor.demo@mediai.dev (min 8 chars):
# SEED_DEMO_PASSWORD=DemoMediai2026!

# --- Email (password reset) ---
# In production, real mail is sent. In development, the reset link is only logged to the console
# unless SEND_REAL_EMAIL_IN_DEV=true.
# Verifying your domain in the provider and setting SPF/DKIM/DMARC is your responsibility.
#
# EMAIL_FROM=MediAI <noreply@yourdomain.com>
# Email provider: resend (default) or smtp
# EMAIL_PROVIDER=resend
#
# Resend (https://resend.com): get API key, verify domain or use onboarding@resend.dev for tests
# RESEND_API_KEY=re_...
#
# SMTP (Nodemailer): use when you already have SMTP (Mailgun, SES, etc.)
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
#
# Optional: set true to send real mail from a dev machine (uses same env as production)
# SEND_REAL_EMAIL_IN_DEV=false

# --- Chapa payments (assistant access + consultation checkout) ---
# Use your sandbox or live secret depending on environment.
# CHAPA_SECRET_KEY=CHASECK_TEST-...
# Optional; not sent on server-side checkout (Bearer secret only). Remove if you
# see Chapa HTTP 400 on initialize when this is set.
# CHAPA_PUBLIC_KEY=
# Defaults to https://api.chapa.co/v1 when unset
# CHAPA_BASE_URL=https://api.chapa.co/v1
# Shared HMAC secret for verifying webhook signatures
# CHAPA_WEBHOOK_SECRET=change-me
# Frontend page Chapa redirects the browser to after checkout
# CHAPA_RETURN_URL=http://localhost:3000/payment/chapa/return
# Optional public GET callback URL; defaults to http://localhost:${PORT}/api/payments/chapa/callback
# CHAPA_CALLBACK_URL=http://localhost:4000/api/payments/chapa/callback
# Public POST webhook URL for Chapa dashboard / ops setup
# CHAPA_WEBHOOK_URL=http://localhost:4000/api/payments/chapa/webhook
# CHAPA_CURRENCY=ETB

# --- Personalized assistant trial (patients) ---
# ASSISTANT_TRIAL_ENABLED=true
# ASSISTANT_TRIAL_LIMIT=3

# --- LLM (chat) ---
# OpenAI-compatible (default): sk-... via LLM_BASE_URL + /v1/chat/completions
# Google Gemini (Google AI key AIza...): auto-detected, or force with LLM_PROVIDER=gemini
# LLM_PROVIDER=openai
# LLM_PROVIDER=gemini
# LLM_API_KEY=
# CHAT_LLM_MODEL=gpt-4o-mini
# Google AI: use a current model id (unversioned gemini-1.5-flash often 404s on v1beta)
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
# With a Google (AIza) key or LLM_PROVIDER=gemini, chat + RAG both use Gemini; EMBEDDING_MODEL is for OpenAI path only

# RAG (pgvector; run: npm run ingest:guidelines — same embedding mode as API)
# RAG_ENABLED=true
# RAG_TOP_K=5
# RAG_MAX_CHUNK_CHARS=2000
# RAG_MIN_SCORE=0
# Ingest + runtime must use the same LLM/embedding provider (OpenAI or Gemini).
# See docs/CHAT_RAG_V1_RUNBOOK.md
